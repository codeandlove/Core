---
/**
 * Checkout Success Page
 * Displayed after successful Stripe Checkout completion
 */

import Layout from "@/layouts/Layout.astro";
import { CheckoutPageThemeWrapper } from "@/components/checkout/CheckoutPageThemeWrapper";

const pageTitle = "Płatność zakończona - Core Starter";
const sessionId = Astro.url.searchParams.get("session_id");
---

<Layout title={pageTitle}>
  <CheckoutPageThemeWrapper client:load>
    <main
      class="container mx-auto flex min-h-screen items-center justify-center px-4 py-12"
    >
      <div class="w-full max-w-2xl text-center">
        <div class="mb-8 flex justify-center">
          <div class="rounded-full bg-green-600/10 p-6 dark:bg-green-400/10">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-16 w-16 text-green-600 dark:text-green-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>

        <h1 class="mb-4 text-3xl font-bold">Dziękujemy za zakup!</h1>

        <p class="mb-8 text-lg text-muted-foreground">
          Twoja subskrypcja została aktywowana. Możesz teraz korzystać z pełnego
          dostępu do funkcji premium.
        </p>

        <div
          class="mb-8 rounded-lg border border-blue-600/20 bg-blue-600/10 p-6 dark:border-blue-400/30 dark:bg-blue-400/10"
        >
          <h2 class="mb-2 text-lg font-semibold">Co dalej?</h2>
          <ul class="space-y-2 text-left text-sm">
            <li class="flex items-start gap-2">
              <span class="mt-1 text-blue-600 dark:text-blue-400">✓</span>
              <span>Twoja subskrypcja jest już aktywna</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1 text-blue-600 dark:text-blue-400">✓</span>
              <span>Otrzymasz potwierdzenie na adres email</span>
            </li>
          </ul>
        </div>

        <div class="flex justify-center">
          <a
            href="/dashboard"
            class="inline-flex items-center justify-center rounded-md bg-blue-600 px-8 py-4 text-lg font-semibold text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:bg-blue-500 dark:hover:bg-blue-600"
          >
            Przejdź do aplikacji
          </a>
        </div>

        {
          sessionId && (
            <p class="mt-8 text-xs text-gray-500">
              ID sesji:{" "}
              <code class="rounded bg-muted px-2 py-1">{sessionId}</code>
            </p>
          )
        }
      </div>
    </main>
  </CheckoutPageThemeWrapper>
</Layout>
