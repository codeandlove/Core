---
/**
 * Login page
 */
import Layout from "@/layouts/Layout.astro";
import { AuthPageWrapper } from "@/components/auth/AuthPageWrapper";
import { AuthPageThemeWrapper } from "@/components/auth/AuthPageThemeWrapper";

const returnUrl = Astro.url.searchParams.get("returnUrl") || "/dashboard";
const passwordReset = Astro.url.searchParams.get("password_reset");
---

<Layout title="Zaloguj się - Core Starter">
  <AuthPageThemeWrapper client:load>
    <div
      class="flex min-h-screen items-center justify-center bg-muted px-4 py-12"
    >
      <div class="w-full max-w-md">
        <div class="mb-8 text-center">
          <a href="/" class="mb-6 inline-flex items-center gap-2">
            <span class="text-3xl">⚡</span>
            <span class="text-2xl font-bold">Core</span>
          </a>
          <h1 class="mt-6 text-3xl font-bold">Zaloguj się</h1>
          <p class="mt-2 text-sm text-muted-foreground">
            Nie masz konta?{" "}
            <a
              href="/auth/register"
              class="font-medium text-primary hover:underline"
            >
              Zarejestruj się
            </a>
          </p>
        </div>

        {
          passwordReset === "success" && (
            <div
              role="alert"
              class="mb-6 rounded-lg border border-green-600/20 bg-green-600/10 p-4 text-sm text-green-700 dark:border-green-400/30 dark:bg-green-400/10 dark:text-green-400"
              id="password-reset-success"
            >
              <p class="font-medium">✅ Hasło zostało pomyślnie zmienione</p>
              <p class="mt-1">
                Możesz teraz zalogować się używając nowego hasła.
              </p>
            </div>
          )
        }

        <AuthPageWrapper client:load mode="login" returnUrl={returnUrl} />
      </div>
    </div>
  </AuthPageThemeWrapper>
</Layout>
