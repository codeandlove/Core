---
/**
 * Reset Password page
 * User sets new password after clicking reset link from email
 */
import Layout from "@/layouts/Layout.astro";
import { PasswordResetPageWrapper } from "@/components/auth/PasswordResetPageWrapper";

// Check for error in URL params (Supabase passes error if token invalid)
const errorType = Astro.url.searchParams.get("error");
const errorDescription = Astro.url.searchParams.get("error_description");
---

<Layout title="Ustaw nowe hasło - Core Starter">
  <div
    class="flex min-h-screen items-center justify-center bg-gray-50 px-4 py-12"
  >
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <a href="/" class="mb-6 inline-flex items-center gap-2">
          <span class="text-3xl">⚡</span>
          <span class="text-2xl font-bold">Core</span>
        </a>
        <h1 class="mt-6 text-3xl font-bold">Ustaw nowe hasło</h1>
        <p class="mt-2 text-sm text-muted-foreground">
          Wprowadź nowe hasło do swojego konta
        </p>
      </div>

      <PasswordResetPageWrapper
        client:only="react"
        mode="reset"
        errorType={errorType}
        errorDescription={errorDescription}
      />

      <div class="mt-6 text-center">
        <a
          href="/auth/login"
          class="text-sm text-muted-foreground hover:underline"
        >
          Powrót do logowania
        </a>
      </div>
    </div>
  </div>
</Layout>
