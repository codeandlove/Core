---
/**
 * Forgot Password page
 * User enters email to receive password reset link
 */
import Layout from "@/layouts/Layout.astro";
import { PasswordResetPageWrapper } from "@/components/auth/PasswordResetPageWrapper";
---

<Layout title="Odzyskaj hasło - Core Starter">
  <div
    class="flex min-h-screen items-center justify-center bg-gray-50 px-4 py-12"
  >
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <a href="/" class="mb-6 inline-flex items-center gap-2">
          <span class="text-3xl">⚡</span>
          <span class="text-2xl font-bold">Core</span>
        </a>
        <h1 class="mt-6 text-3xl font-bold">Odzyskaj hasło</h1>
        <p class="mt-2 text-sm text-muted-foreground">
          Wprowadź swój adres email, a wyślemy Ci link do resetowania hasła
        </p>
      </div>

      <PasswordResetPageWrapper client:only="react" mode="forgot" />

      <div class="mt-6 text-center">
        <a
          href="/auth/login"
          class="text-sm text-muted-foreground hover:underline"
        >
          Powrót do logowania
        </a>
      </div>
    </div>
  </div>
</Layout>
